			"name": "Universal Login (All Roles)",
			"item": [
				{
					"name": "Universal Login - Admin",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"if (pm.response.code === 200) {",
									"    var jsonData = pm.response.json();",
									"    var type = jsonData.data.type;",
									"    var token = jsonData.data.token;",
									"    ",
									"    // Save token based on type",
									"    if (type === 'admin') {",
									"        pm.collectionVariables.set('admin_token', token);",
									"    } else if (type === 'client') {",
									"        pm.collectionVariables.set('client_token', token);",
									"    } else if (type === 'designer') {",
									"        pm.collectionVariables.set('designer_token', token);",
									"    } else if (type === 'marketer') {",
									"        pm.collectionVariables.set('marketer_token', token);",
									"    }",
									"}"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							},
							{
								"key": "Accept-Language",
								"value": "en",
								"description": "Language: en or ar"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"identifier\": \"testadmin\",\n    \"password\": \"password123\"\n}"
						},
						"url": {
							"raw": "{{base_url}}/login",
							"host": ["{{base_url}}"],
							"path": ["login"]
						}
					}
